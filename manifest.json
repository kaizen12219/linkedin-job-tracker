{
  "manifest_version": 3,
  "name": "LinkedIn Job Scraper",
  "description": "Scrape the current LinkedIn job title, company, description, and apply URL.",
  "version": "0.1.0",
  "action": {
    "default_title": "Scrape LinkedIn Job",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": ["activeTab", "clipboardWrite", "scripting", "storage"],
  "host_permissions": [
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://www.linkedin.com/*",
    "http://127.0.0.1/*",
    "https://plank-undergo-sandbag.ngrok-free.dev/*"
  ],
  "commands": {
    "scrape-and-save-job": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Scrape the active LinkedIn job and save it to Google Sheets"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs/view/*",
        "https://www.linkedin.com/jobs/search-results/*"
      ],
      "js": ["src/scraper.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
